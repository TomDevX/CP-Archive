{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Compile and Run cpp",
            "type": "shell",
            // Đã chuyển đổi các biến sang chuẩn VS Code và thêm ngoặc kép để tránh lỗi nếu tên thư mục có dấu cách
            "command": "cd \"${fileDirname}\" && g++ -O2 -Wall -Wextra -Wshadow -Wfloat-equal -DLOCAL --std=c++14 \"${fileBasename}\" -o \"${fileBasenameNoExtension}\" && \"./${fileBasenameNoExtension}\" < /home/TomDev/CP-Archive/Solutions/input.inp > /home/TomDev/CP-Archive/Solutions/output.out",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared",
                "clear": true,
                "showReuseMessage": false
            },
            "problemMatcher": ["$gcc"]
        },
        {
            "label": "Compile and Run cpp without file",
            "type": "shell",
            // Đã chuyển đổi các biến sang chuẩn VS Code và thêm ngoặc kép để tránh lỗi nếu tên thư mục có dấu cách
            "command": "cd \"${fileDirname}\" && g++ -O2 -Wall -Wextra -Wshadow -Wfloat-equal -DLOCAL --std=c++14 \"${fileBasename}\" -o \"${fileBasenameNoExtension}\" && \"./${fileBasenameNoExtension}\"",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared",
                "clear": true,
                "showReuseMessage": false
            },
            "problemMatcher": ["$gcc"]
        },
		{
            "label": "Get compile file",
