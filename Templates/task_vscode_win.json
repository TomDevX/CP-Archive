{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Compile and Run cpp",
            "type": "shell",
            "command": "g++ -O2 -pipe -static -march=native -std=c++14 \"${fileBasename}\" -o \"${fileBasenameNoExtension}\" -Wall -Wextra -Wshadow -Wfloat-equal -Wno-unused-result -Wno-unused-parameter -DLOCAL -lm && \"./${fileBasenameNoExtension}\" < /home/CP-Archive/Solutions/input.inp > /home/CP-Archive/Solutions/output.out",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "options": {
                "cwd": "${fileDirname}",
                // "shell": {
                //     "executable": "/bin/bash",
                //     "args": ["--norc","-c"]
                // }
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared",
                "clear": true,
                "showReuseMessage": false
            },
            "problemMatcher": ["$gcc"]
        },
        {
            "label": "Compile and Run C",
            "type": "shell",
            "command": "cd \"${fileDirname}\" && gcc -O2 -pipe -static -Wall -Wextra -Wshadow -Wfloat-equal -Wno-unused-result -Wno-unused-parameter -DLOCAL -lm -march=native --std=c11 \"${fileBasename}\" -o \"${fileBasenameNoExtension}\" && time ./\"${fileBasenameNoExtension}\" < /home/CP-Archive/Solutions/input.inp > /home/CP-Archive/Solutions/output.out",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "options": {
                "cwd": "${fileDirname}",
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared",
                "clear": true,
                "showReuseMessage": false
            },
            "problemMatcher": ["$gcc"]
        },
        {
